# Copie ce fichier en ".env" et remplis les valeurs.

# ── Serveur ────────────────────────────────────────────────────
# Port d'écoute du serveur.
PORT=3000

# ── Admin ──────────────────────────────────────────────────────
# Compte admin créé au premier démarrage — CHANGE CES VALEURS
# Minimum 8 caractères pour le mot de passe
ADMIN_USER=admin
ADMIN_PASS=change-moi-absolument

# ── Base de données ────────────────────────────────────────────
# Local (dev) : laisser vide pour utiliser ./blackstate.db
# Docker      : définir sur /app/data/blackstate.db (volume persistant)
DB_FILE=/app/data/blackstate.db

# ── Turnstile (CAPTCHA anti-bot, optionnel) ────────────────────
# Active le captcha sur login + inscription si LES DEUX sont définies.
# Laisser vide en dev → captcha désactivé, formulaires normaux.
# Clé de site = PUBLIQUE ; clé secrète = SERVEUR UNIQUEMENT (jamais commitée).
# Récupère-les dans Cloudflare → Turnstile → ton widget.
TURNSTILE_SITE_KEY=
TURNSTILE_SECRET_KEY=

# ── CORS (optionnel) ───────────────────────────────────────────
# Origine autorisée à appeler l'API depuis un autre domaine.
# Laisser vide si le front est servi par le même serveur Express.
# ALLOWED_ORIGIN=https://casino.ton-domaine.com
