# Copie ce fichier en ".env" (ou définis ces variables sur ton hébergeur).
# Aucune n'est obligatoire : des valeurs par défaut existent.

# Port d'écoute (Render/Railway le fournissent automatiquement)
PORT=3000

# Identifiants du compte admin créé au premier démarrage (À CHANGER)
ADMIN_USER=admin
ADMIN_PASS=change-moi

# Emplacement du fichier base de données SQLite
DB_FILE=./casino.db
