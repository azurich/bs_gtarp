# Reverse-proxy + HTTPS automatique (Let's Encrypt).
# Remplace "casino.ton-domaine.com" par ton vrai domaine (un enregistrement
# DNS A doit pointer vers l'IP du VPS). Caddy gère le certificat tout seul.

casino.ton-domaine.com {
    reverse_proxy localhost:3000
    encode gzip
}

