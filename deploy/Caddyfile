# Reverse-proxy + HTTPS automatique (Let's Encrypt).
# Un enregistrement DNS A "blackstate" doit pointer vers l'IP du VPS.
# Caddy gère le certificat tout seul.

blackstate.azurich.fr {
    reverse_proxy localhost:3000
    encode gzip
}

